{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../../",
  "testEnvironment": "node",
  "testRegex": "tests/api_tests/.*\\.e2e-spec\\.ts$",
  "transform": {
    "^.+\\.(t|j)s$": "ts-jest"
  },
  "collectCoverageFrom": [
    "src/modules/**/*.controller.ts",
    "src/app.controller.ts"
  ],
  "coverageDirectory": "coverage-e2e",
  "coverageThreshold": {
    "global": {
      "statements": 90,
      "functions": 90,
      "lines": 90,
      "branches": 90
    }
  },
  "moduleNameMapper": {
    "^@/(.*)$": "<rootDir>/src/$1"
  }
}
